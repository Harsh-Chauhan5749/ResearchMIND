# =============================================================
#  ResearchMind AI - Environment Configuration
# =============================================================
#
# CHOOSE ONE FREE LLM PROVIDER:
#
# OPTION 1 — GROQ (RECOMMENDED: fastest, best quality)
#   Sign up free at: https://console.groq.com
#   Get API key → API Keys → Create Key
#   Supports: Llama 3.1 70B, Mixtral 8x7B (30 req/min free)
#
# OPTION 2 — GOOGLE GEMINI
#   Sign up free at: https://ai.google.dev
#   Get API key → Get API Key
#   Supports: Gemini 1.5 Flash (15 req/min free)
#
# OPTION 3 — OLLAMA (fully offline, no API key needed)
#   Install from: https://ollama.ai
#   Run: ollama pull llama3.2
#   Then set LLM_PROVIDER=ollama below
#
# =============================================================

LLM_PROVIDER=groq

# Groq Settings
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-70b-versatile

# Gemini Settings
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Ollama Settings (if using offline)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
